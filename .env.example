# Xiaomi MiMo API key. Keep the real .env file local and untracked.
MIMO_API_KEY=your_api_key_here

# OpenAI-compatible MiMo endpoint.
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# Multimodal model used by the OCR workspace.
MIMO_MODEL=mimo-v2.5

# Sibling clone of the records repository.
MATH_RECORDS_DIR=../records

# Optional: clone records automatically if MATH_RECORDS_DIR does not exist.
MATH_RECORDS_REPO_URL=https://github.com/your-name/your-records-repo.git

# Set to 0 to disable safe auto-sync on dashboard load.
AUTO_SYNC_RECORDS=1
